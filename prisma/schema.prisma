generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum LocationStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum AssetStatus {
  AVAILABLE
  RESERVED
  ALLOCATED
  RETURNED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  UNUSABLE
}

enum AssetCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DOUBLE_DECLINING_BALANCE
  UNITS_OF_PRODUCTION
  SUM_OF_YEARS_DIGITS
  NONE
}

enum FileKind {
  IMAGE
  DOCUMENT
  INVOICE
  WARRANTY
  OTHER
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  CANCELLED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum ResourceType {
  ASSET
  ROOM
  EQUIPMENT
  VEHICLE
  OTHER
}

enum ResourceStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  RETIRED
}

enum BookingStatus {
  HELD
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  EXPIRED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  ASSIGNED
  IN_REPAIR
  RESOLVED
  CANCELLED
}

enum AuditCycleStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum AuditRecordStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
  MOVED
}

enum NotificationType {
  APPROVAL
  MAINTENANCE
  BOOKING
  TRANSFER
  RETURN
  SYSTEM
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  APPROVED
  REJECTED
  ALLOCATED
  RETURNED
  TRANSFERRED
  BOOKED
  CANCELLED
  RESOLVED
  AUDITED
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  timezone  String    @default("UTC")
  currency  String    @default("USD")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  roles            Role[]
  departments      Department[]
  locations        Location[]
  users            User[]
  assetCategories  AssetCategory[]
  assets           Asset[]
  resources        Resource[]
  allocations      AssetAllocation[]
  transferRequests TransferRequest[]
  bookings         ResourceBooking[]
  maintenance      MaintenanceRequest[]
  auditCycles      AuditCycle[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  histories        AssetHistory[]
  businessRules    BusinessRule[]
  idempotencyKeys  IdempotencyKey[]
  sessions         Session[]

  @@index([isActive])
}

model Role {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  description    String?
  permissions    Json?
  isSystem       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  userRoles UserRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  departmentId   String?
  department     Department?  @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  employeeCode   String?
  firstName      String
  lastName       String
  email          String
  passwordHash   String
  phone          String?
  avatarUrl      String?
  status         UserStatus   @default(ACTIVE)
  lastLoginAt    DateTime?
  version        Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  userRoles              UserRole[]
  headedDepartments      Department[]         @relation("DepartmentHead")
  createdAssets          Asset[]              @relation("AssetCreator")
  uploadedFiles          AssetFile[]          @relation("AssetFileUploader")
  allocationsReceived    AssetAllocation[]    @relation("AllocatedTo")
  allocationsMade        AssetAllocation[]    @relation("AllocatedBy")
  allocationsReturned    AssetAllocation[]    @relation("ReturnedBy")
  transferRequestsMade   TransferRequest[]    @relation("TransferRequester")
  transferRequestsTarget TransferRequest[]    @relation("TransferTarget")
  transferApprovals      TransferRequest[]    @relation("TransferApprover")
  bookings               ResourceBooking[]    @relation("BookedBy")
  maintenanceRequested   MaintenanceRequest[] @relation("MaintenanceRequester")
  maintenanceApproved    MaintenanceRequest[] @relation("MaintenanceApprover")
  maintenanceAssigned    MaintenanceRequest[] @relation("Technician")
  auditCyclesCreated     AuditCycle[]         @relation("AuditCreator")
  auditAssignments       AuditCycle[]         @relation("AuditAssignee")
  auditRecords           AuditRecord[]        @relation("Auditor")
  notifications          Notification[]
  activityLogs           ActivityLog[]        @relation("ActivityActor")
  assetHistories         AssetHistory[]       @relation("AssetHistoryActor")
  sessions               Session[]
  idempotencyKeys        IdempotencyKey[]

  // Partial unique constraint implemented via migration: UNIQUE (organizationId, email) WHERE deletedAt IS NULL
  @@index([organizationId, status])
  @@index([departmentId])
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  assignedAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
}

model Session {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash      String       @unique
  ipAddress      String?
  userAgent      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId, userId])
  @@index([expiresAt])
}

model Location {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parentId       String?
  parent         Location?      @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children       Location[]     @relation("LocationHierarchy")
  name           String
  code           String
  status         LocationStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  assets         Asset[]
  resources      Resource[]
  transferRequests TransferRequest[]

  // Partial unique constraint via migration: UNIQUE (organizationId, code) WHERE deletedAt IS NULL
  @@index([organizationId, status])
  @@index([parentId])
}

model Department {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parentId       String?
  parent         Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children       Department[]     @relation("DepartmentHierarchy")
  headUserId     String?
  headUser       User?            @relation("DepartmentHead", fields: [headUserId], references: [id], onDelete: SetNull)
  name           String
  code           String
  status         DepartmentStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  users       User[]       @relation("DepartmentMembers")
  assets      Asset[]
  auditCycles AuditCycle[]
  transferRequests TransferRequest[]

  // Partial unique constraint via migration: UNIQUE (organizationId, code) WHERE deletedAt IS NULL
  @@index([organizationId, status])
  @@index([parentId])
}

model AssetCategory {
  id                    String          @id @default(cuid())
  organizationId        String
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parentId              String?
  parent                AssetCategory?  @relation("AssetCategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children              AssetCategory[] @relation("AssetCategoryHierarchy")
  name                  String
  code                  String
  description           String?
  defaultWarrantyMonths Int?
  expectedLifeMonths    Int?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?

  assets Asset[]

  // Partial unique constraint via migration: UNIQUE (organizationId, code) WHERE deletedAt IS NULL
  @@index([parentId])
}

model Asset {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assetTag       String
  serialNumber   String
  name           String
  description    String?
  categoryId     String
  category       AssetCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  departmentId   String
  department     Department       @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  locationId     String
  location       Location         @relation(fields: [locationId], references: [id], onDelete: Restrict)
  purchaseDate   DateTime?
  currency       String           @default("USD")
  purchaseCost   Decimal?         @db.Decimal(14, 2)
  salvageValue   Decimal?         @db.Decimal(14, 2)
  depreciationMethod DepreciationMethod? @default(STRAIGHT_LINE)
  warrantyExpiry DateTime?
  condition      AssetCondition   @default(GOOD)
  criticality    AssetCriticality @default(MEDIUM)
  status         AssetStatus      @default(AVAILABLE)
  isAllocatable  Boolean          @default(true)
  version        Int              @default(1)
  createdById    String
  createdBy      User             @relation("AssetCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  files            AssetFile[]
  allocations      AssetAllocation[]
  activeAllocation ActiveAssetAllocation?
  transferRequests TransferRequest[]
  resource         Resource?
  maintenance      MaintenanceRequest[]
  auditRecords     AuditRecord[]
  history          AssetHistory[]

  // Partial unique constraints via migration: 
  // UNIQUE (organizationId, assetTag) WHERE deletedAt IS NULL
  // UNIQUE (organizationId, serialNumber) WHERE deletedAt IS NULL
  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@index([organizationId, categoryId])
  @@index([organizationId, locationId])
  @@index([deletedAt])
}

model AssetFile {
  id                 String    @id @default(cuid())
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id], onDelete: Restrict)
  uploadedById       String
  uploadedBy         User      @relation("AssetFileUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  kind               FileKind  @default(OTHER)
  fileName           String
  mimeType           String
  byteSize           Int?
  cloudinaryPublicId String?
  url                String
  checksum           String?
  createdAt          DateTime  @default(now())
  deletedAt          DateTime?

  @@index([assetId, kind])
}

model AssetAllocation {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assetId           String
  asset             Asset            @relation(fields: [assetId], references: [id], onDelete: Restrict)
  allocatedToUserId String
  allocatedTo       User             @relation("AllocatedTo", fields: [allocatedToUserId], references: [id], onDelete: Restrict)
  allocatedById     String
  allocatedBy       User             @relation("AllocatedBy", fields: [allocatedById], references: [id], onDelete: Restrict)
  returnedById      String?
  returnedBy        User?            @relation("ReturnedBy", fields: [returnedById], references: [id], onDelete: Restrict)
  allocatedAt       DateTime         @default(now())
  expectedReturnAt  DateTime?
  returnedAt        DateTime?
  status            AllocationStatus @default(ACTIVE)
  issueNotes        String?
  returnNotes       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  activeLock       ActiveAssetAllocation?
  transferRequests TransferRequest[]

  @@index([organizationId, assetId, status])
  @@index([organizationId, allocatedToUserId, status])
  @@index([expectedReturnAt])
}

model ActiveAssetAllocation {
  assetId      String          @id
  asset        Asset           @relation(fields: [assetId], references: [id], onDelete: Restrict)
  allocationId String          @unique
  allocation   AssetAllocation @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  createdAt    DateTime        @default(now())
}

model TransferRequest {
  id                 String          @id @default(cuid())
  organizationId     String
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  allocationId       String?
  allocation         AssetAllocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  assetId            String
  asset              Asset           @relation(fields: [assetId], references: [id], onDelete: Restrict)
  requestedById      String
  requestedBy        User            @relation("TransferRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  
  targetUserId       String?
  targetUser         User?           @relation("TransferTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetDepartmentId String?
  targetDepartment   Department?     @relation(fields: [targetDepartmentId], references: [id], onDelete: SetNull)
  targetLocationId   String?
  targetLocation     Location?       @relation(fields: [targetLocationId], references: [id], onDelete: SetNull)

  approvedById       String?
  approvedBy         User?           @relation("TransferApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  reason             String
  status             TransferStatus  @default(REQUESTED)
  requestedAt        DateTime        @default(now())
  approvedAt         DateTime?
  completedAt        DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  version            Int             @default(1)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([organizationId, status])
  @@index([allocationId, status])
  @@index([targetUserId, status])
}

model Resource {
  id                  String         @id @default(cuid())
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assetId             String?        @unique
  asset               Asset?         @relation(fields: [assetId], references: [id], onDelete: Restrict)
  locationId          String?
  location            Location?      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  type                ResourceType
  name                String
  code                String
  capacity            Int?
  status              ResourceStatus @default(ACTIVE)
  minBookingMinutes   Int            @default(15)
  maxBookingMinutes   Int?
  bufferBeforeMinutes Int            @default(0)
  bufferAfterMinutes  Int            @default(0)
  holdMinutes         Int            @default(10)
  timezone            String         @default("UTC")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  bookings ResourceBooking[]

  // Partial unique constraint via migration: UNIQUE (organizationId, code) WHERE deletedAt IS NULL
  @@index([organizationId, type, status])
}

model ResourceBooking {
  id                 String        @id @default(cuid())
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  resourceId         String
  resource           Resource      @relation(fields: [resourceId], references: [id], onDelete: Restrict)
  bookedById         String
  bookedBy           User          @relation("BookedBy", fields: [bookedById], references: [id], onDelete: Restrict)
  startAt            DateTime
  endAt              DateTime
  isRecurring        Boolean       @default(false)
  recurrenceRule     String?
  holdExpiresAt      DateTime?
  purpose            String?
  status             BookingStatus @default(HELD)
  timezone           String        @default("UTC")
  checkedInAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  version            Int           @default(1)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Overlap exclusion constraint to be added via raw SQL migration
  @@index([organizationId, resourceId, startAt, endAt])
  @@index([organizationId, bookedById, status])
  @@index([holdExpiresAt])
}

model MaintenanceRequest {
  id                   String              @id @default(cuid())
  organizationId       String
  organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assetId              String
  asset                Asset               @relation(fields: [assetId], references: [id], onDelete: Restrict)
  requestedById        String
  requestedBy          User                @relation("MaintenanceRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedById         String?
  approvedBy           User?               @relation("MaintenanceApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  assignedTechnicianId String?
  assignedTechnician   User?               @relation("Technician", fields: [assignedTechnicianId], references: [id], onDelete: Restrict)
  issue                String
  priority             MaintenancePriority @default(MEDIUM)
  status               MaintenanceStatus   @default(PENDING)
  cost                 Decimal?            @db.Decimal(14, 2)
  currency             String              @default("USD")
  approvedAt           DateTime?
  assignedAt           DateTime?
  startedAt            DateTime?
  resolvedAt           DateTime?
  rejectedAt           DateTime?
  resolutionNotes      String?
  version              Int                 @default(1)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([organizationId, assetId, status])
  @@index([organizationId, status, priority])
  @@index([assignedTechnicianId, status])
}

model AuditCycle {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  departmentId      String?
  department        Department?      @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  title             String
  description       String?
  status            AuditCycleStatus @default(OPEN)
  plannedStartAt    DateTime
  plannedEndAt      DateTime
  startedAt         DateTime?
  closedAt          DateTime?
  createdById       String
  createdBy         User             @relation("AuditCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignedAuditorId String?
  assignedAuditor   User?            @relation("AuditAssignee", fields: [assignedAuditorId], references: [id], onDelete: Restrict)
  version           Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  records AuditRecord[]

  @@index([organizationId, status])
  @@index([departmentId])
}

model AuditRecord {
  id                String            @id @default(cuid())
  auditCycleId      String
  auditCycle        AuditCycle        @relation(fields: [auditCycleId], references: [id], onDelete: Restrict)
  assetId           String
  asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Restrict)
  auditorId         String
  auditor           User              @relation("Auditor", fields: [auditorId], references: [id], onDelete: Restrict)
  status            AuditRecordStatus @default(PENDING)
  observedCondition AssetCondition?
  observedLocation  String?
  remarks           String?
  verifiedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([auditCycleId, assetId])
  @@index([assetId])
  @@index([auditorId, status])
}

model Notification {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           NotificationType
  severity       NotificationSeverity @default(INFO)
  title          String
  message        String
  entityType     String?
  entityId       String?
  readAt         DateTime?
  createdAt      DateTime             @default(now())

  @@index([organizationId, userId, readAt])
  @@index([entityType, entityId])
}

model ActivityLog {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  actorId        String?
  actor          User?          @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole      String?
  action         ActivityAction
  entityType     String
  entityId       String
  previousState  Json?
  newState       Json?
  metadata       Json?
  reason         String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())

  @@index([organizationId, entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model AssetHistory {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assetId        String
  asset          Asset          @relation(fields: [assetId], references: [id], onDelete: Restrict)
  actorId        String?
  actor          User?          @relation("AssetHistoryActor", fields: [actorId], references: [id], onDelete: SetNull)
  action         ActivityAction
  previousState  Json?
  newState       Json?
  reason         String?
  metadata       Json?
  createdAt      DateTime       @default(now())

  @@index([organizationId, assetId, createdAt])
}

model BusinessRule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String
  value          Json
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key])
}

model IdempotencyKey {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  key            String
  requestHash    String
  route          String
  status         IdempotencyStatus @default(PROCESSING)
  responseCode   Int?
  responseBody   Json?
  lockedUntil    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId, route])
  @@index([lockedUntil])
}
